# --- Application runtime (Cloud Run Job and local) ---
SLACK_USER_TOKEN=xoxp-your-user-token
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Text-only model used for optional Slack profile title (cargo) when UPDATE_SLACK_TITLE is on.
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# When 1/true/yes/on, generate a corporate-satire phrase with Gemini each run after the photo uploads.
# UPDATE_SLACK_TITLE=1
# If set, never fall back to the raw base photo when Gemini returns 429/quota errors.
# STRICT_GEMINI=1
TZ=America/Santiago

# Optional: fixed RNG seed (integer) for reproducible prompt/image picks.
# RUN_SEED=

ASSETS_DIR=assets/images
PROMPTS_PATH=prompts.json
# Optional personal vacation calendar (gitignored; copy from vacations.example.json).
# VACATIONS_PATH=vacations.json
OUTPUT_DIR=output

# --- GCP service account (optional; for deploy container) ---
# Place the JSON key at credentials/gcp-sa.json (gitignored) or set GCP_SERVICE_ACCOUNT_KEY to another host path.
# Uncomment both lines below to use the service account with docker compose (merges docker-compose.gcp-sa.yml):
# COMPOSE_FILE=docker-compose.yml:docker-compose.gcp-sa.yml
# GCP_SERVICE_ACCOUNT_KEY=./credentials/gcp-sa.json
# Use ./ or an absolute path (not a bare filename); otherwise Compose may treat it as a named volume.
#
# Or run: docker compose -f docker-compose.yml -f docker-compose.gcp-sa.yml run --rm deploy …
#
# docker-compose.gcp-sa.yml sets GOOGLE_APPLICATION_CREDENTIALS inside the container; you do not
# need that variable in .env when using the fragment. Deploy scripts activate that key for gcloud/docker.
#
# Human gcloud login from the host: add docker-compose.gcloud-user.yml to COMPOSE_FILE, e.g.
#   COMPOSE_FILE=docker-compose.yml:docker-compose.gcloud-user.yml
# then run: docker compose run --rm deploy gcloud auth login

# --- GCP project and region (deploy scripts) ---
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1

# --- Artifact Registry image (deploy scripts) ---
AR_REPO=docker-repo
IMAGE_NAME=auto-slack-avatar
IMAGE_TAG=latest
# Optional: full URI; if set, overrides REGION-docker.pkg.dev/PROJECT/REPO/NAME:TAG
# IMAGE_URI=us-central1-docker.pkg.dev/your-gcp-project-id/docker-repo/auto-slack-avatar:latest

# --- Cloud Run Job (deploy scripts) ---
CLOUD_RUN_JOB_NAME=auto-slack-avatar-job
# Optional: task execution service account email
# CLOUD_RUN_JOB_SERVICE_ACCOUNT=789...@PROJECT_ID.iam.gserviceaccount.com
# Optional: retries and timeout for each task
# CLOUD_RUN_MAX_RETRIES=1
# CLOUD_RUN_TASK_TIMEOUT=10m

# --- Cloud Scheduler (deploy scripts; same region as GCP_REGION in typical setups) ---
SCHEDULER_JOB_NAME=auto-slack-avatar-scheduler
SCHEDULER_CRON=0 * * * *
SCHEDULER_TIME_ZONE=America/Santiago
# Service account that invokes the Cloud Run Job (needs run.jobs.run on the job)
SCHEDULER_SERVICE_ACCOUNT=scheduler-invoker@your-gcp-project-id.iam.gserviceaccount.com

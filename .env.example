SLACK_USER_TOKEN=xoxp-your-user-token
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Text-only model used for optional Slack profile title (cargo) when UPDATE_SLACK_TITLE is on.
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# When 1/true/yes/on, generate a corporate-satire phrase with Gemini each run after the photo uploads.
# UPDATE_SLACK_TITLE=1
# If set, never fall back to the raw base photo when Gemini returns 429/quota errors.
# STRICT_GEMINI=1
TZ=America/Santiago

# Optional: fixed RNG seed (integer) for reproducible prompt/image picks.
# RUN_SEED=

ASSETS_DIR=assets/images
PROMPTS_PATH=prompts.json
OUTPUT_DIR=output
